# MeterPulse environment configuration
# Copy to .env and fill in real values. The app refuses to start
# without SECRET_KEY (fail-fast: never run on a known dev key).

# PostgreSQL connection string (production)
DATABASE_URL=postgresql://user:password@localhost:5432/meterpulse
# For quick local development you can use SQLite instead:
# DATABASE_URL=sqlite:///./meterpulse.db

# JWT signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Allowed frontend origins (JSON list)
CORS_ORIGINS=["http://localhost:3000"]

# Optional
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# RATE_LIMIT_ENABLED=true
# DEBUG=false
